{
  "name": "codex-buildathon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "codex": "./scripts/codex/run.sh",
    "codex:full": "CODEX_FULL_AUTO=1 ./scripts/codex/run.sh",
    "codex:review": "./scripts/codex/review.sh --uncommitted",
    "codex:search": "CODEX_ENABLE_SEARCH=1 ./scripts/codex/run.sh",
    "codex:setup": "./scripts/codex/setup.sh",
    "agent:start": "node ./scripts/agent/cli.mjs start",
    "agent:chat": "node ./scripts/agent/cli.mjs chat",
    "agent:status": "node ./scripts/agent/cli.mjs status",
    "agent:logs": "node ./scripts/agent/cli.mjs logs",
    "agent:approve": "node ./scripts/agent/cli.mjs approve",
    "agent:changes": "node ./scripts/agent/cli.mjs changes",
    "agent:stop": "node ./scripts/agent/cli.mjs stop",
    "sdlc:init": "node ./scripts/sdlc/cli.mjs init",
    "sdlc:status": "node ./scripts/sdlc/cli.mjs status",
    "sdlc:run": "node ./scripts/sdlc/cli.mjs run",
    "sdlc:approve": "node ./scripts/sdlc/cli.mjs approve",
    "sdlc:changes": "node ./scripts/sdlc/cli.mjs changes",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "mermaid": "^11.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.2.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "wait-on": "^8.0.5"
  }
}
